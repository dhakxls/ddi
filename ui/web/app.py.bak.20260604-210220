@app.get("/api/compounds")
async def list_compounds():
    """List available curated compounds."""
    curated_dir = Path(__file__).parent.parent.parent / "data" / "curated"
    
    if not curated_dir.exists():
        return {"compounds": []}
    
    compounds = []
    for json_file in curated_dir.glob("*.json"):
        if json_file.name != "compound_tracking_sheet.xlsx" and not json_file.name.endswith(".md"):
            try:
                with open(json_file, 'r') as f:
                    data = json.load(f)
                    compounds.append({
                        "id": json_file.stem,
                        "name": data.get("compound_name", "Unknown"),
                        "quality_rating": data.get("curation_metadata", {}).get("quality_rating", "")
                    })
            except:
                pass
    
    return {"compounds": compounds}


@app.get("/api/compounds/{compound_id}")
async def get_compound(compound_id: str):
    """Get compound data by ID."""
    curated_dir = Path(__file__).parent.parent.parent / "data" / "curated"
    compound_file = curated_dir / f"{compound_id}.json"
    
    if not compound_file.exists():
        raise HTTPException(status_code=404, detail="Compound not found")
    
    with open(compound_file, 'r') as f:
        return json.load(f)


