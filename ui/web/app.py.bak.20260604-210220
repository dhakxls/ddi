@lru_cache(maxsize=1)
def load_annotation_index() -> dict[str, dict]:
    index: dict[str, dict] = {}
    if not ANNOTATIONS_PATH.exists():
        return index
    for payload_path in ANNOTATIONS_PATH.glob("*_annotations.json"):
        try:
            with open(payload_path, "r") as fh:
                payload = json.load(fh)
            for record in payload.get("records", []):
                key = (record.get("compound_key") or "").lower()
                if key:
                    index[key] = record.get("enzyme_data", {})
        except Exception:
            continue
    return index


# Pydantic models for API
class EnzymeData(BaseModel):
    is_substrate: bool = False
    km_um: Optional[float] = None
    vmax: Optional[float] = None
    clint: Optional[float] = None
    fm: Optional[float] = None
    source: str = ""


class InhibitionData(BaseModel):
    is_inhibitor: bool = False
    inhibition_type: Optional[str] = None
    ic50_um: Optional[float] = None
    ki_um: Optional[float] = None
    source: str = ""


class InductionData(BaseModel):
    is_inducer: bool = False
    induction_type: Optional[str] = None
    fold_change: Optional[float] = None
    source: str = ""


class CompoundInput(BaseModel):
    compound_name: str
    substrate_data: Dict[str, EnzymeData]
    inhibition_data: Dict[str, InhibitionData]
    induction_data: Dict[str, InductionData]


class DrugPairInput(BaseModel):
    drug_a: CompoundInput
    drug_b: CompoundInput


