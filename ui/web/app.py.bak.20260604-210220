@app.get("/api/fetch/drug/{drug_name}")
async def fetch_drug_data(drug_name: str):
    """
    Fetch drug data from APIs dynamically.
    
    Args:
        drug_name: Name of the drug to fetch
    
    Returns:
        Drug data from APIs
    """
    try:
        # Fetch data from APIs
        api_data = data_merger.get_consolidated_drug_data(drug_name)
        
        # Convert to UI format
        enzyme_data = {
            "substrate": {},
            "inhibition": {},
            "induction": {}
        }
        
        # Seed from offline annotations if available
        annotation_index = load_annotation_index()
        annotation_key = drug_name.strip().lower()
        if annotation_key in annotation_index:
            for category, enzymes in annotation_index[annotation_key].items():
                enzyme_data.setdefault(category, {}).update(enzymes)

        # Add enzyme mentions from API (as substrate mentions)
        if api_data.enzyme_data:
            for enzyme in api_data.enzyme_data.keys():
                enzyme_data["substrate"][enzyme] = {
                    "is_substrate": True,
                    "fm": None,
                    "source": "OpenFDA API"
                }
        
        # Check ChEMBL for inhibition data
        chembl_data = data_merger.chembl.get_compound_targets(drug_name)
        if chembl_data and chembl_data.get("enzyme_targets"):
            for enzyme, target_info in chembl_data["enzyme_targets"].items():
                activities = target_info.get("activities", [])
                for activity in activities:
                    activity_type = activity.get("type", "").lower()
                    value = activity.get("value")
                    
                    # Check for inhibition data (IC50, Ki)
                    if activity_type in ["ic50", "ki", "ki (binding)"] and value:
                        try:
                            ic50_value = float(value)
                            # Determine inhibition type based on IC50 value
                            if ic50_value < 1:
                                inhibition_type = "strong"
                            elif ic50_value < 10:
                                inhibition_type = "moderate"
                            else:
                                inhibition_type = "weak"
                            
                            enzyme_data["inhibition"][enzyme] = {
                                "is_inhibitor": True,
                                "inhibition_type": inhibition_type,
                                "ic50_um": ic50_value,
                                "source": "ChEMBL API"
                            }
                        except:
                            pass
        
        return {
            "compound_name": drug_name,
            "smiles": api_data.smiles,
            "molecular_weight": api_data.molecular_weight,
            "enzyme_data": enzyme_data,
            "sources": api_data.sources,
            "fm_data": api_data.fm_data
        }
    
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


